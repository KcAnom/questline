{
  "name": "questline",
  "version": "0.1.1",
  "description": "Durable, crash-safe work queue and TUI for CLI coding agents (claude, pi, codex, \u2026): leases with fencing, heartbeats, retries with backoff, dependencies, priorities, scheduling, dedupe, per-attempt telemetry.",
  "type": "module",
  "bin": {
    "questline": "bin/questline.js"
  },
  "engines": {
    "node": ">=22.11"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "agent",
    "queue",
    "tui",
    "cli",
    "durable",
    "claude",
    "orchestration"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KcAnom/questline.git"
  },
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}